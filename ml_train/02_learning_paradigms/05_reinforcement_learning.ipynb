   "source": [
    "## 5. 离线强化学习\n",
    "\n",
    "**目的**：从固定数据集中学习策略，不需要与环境实时交互\n",
    "\n",
    "**基本原理**：离线RL仅从预先收集的数据中学习策略，适用于无法在线采样的场景。DPO可视为离线RL的一种形式——它直接在固定的偏好数据集上优化策略，无需在线采样和环境交互。\n",
    "\n",
    "**DPO与离线RL的关系**：\n",
    "- DPO将RLHF的奖励最大化问题转化为分类问题\n",
    "- 不需要训练奖励模型和在线采样\n",
    "- 直接在偏好数据上优化策略\n",
    "- 本质上是一种隐式的离线RL方法"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.nn.functional as F\n",
    "\n",
    "torch.manual_seed(42)\n",
    "\n",
    "class OfflineRLPolicy(nn.Module):\n",
    "    def __init__(self, dim=16, n_actions=4):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(nn.Linear(dim, 32), nn.ReLU(), nn.Linear(32, n_actions))\n",
    "    def forward(self, x):\n",
    "        return self.net(x)\n",
    "\n",
    "policy = OfflineRLPolicy()\n",
    "ref_policy = OfflineRLPolicy()\n",
    "ref_policy.load_state_dict(policy.state_dict())\n",
    "ref_policy.eval()\n",
    "optimizer = torch.optim.Adam(policy.parameters(), lr=1e-3)\n",
    "\n",
    "n_data = 200\n",
    "states = torch.randn(n_data, 16)\n",
    "chosen_actions = torch.randint(0, 4, (n_data,))\n",
    "rejected_actions = torch.randint(0, 4, (n_data,))\n",
    "chosen_actions[:100] = 0\n",
    "rejected_actions[:100] = 1\n",
    "\n",
    "print('=== Offline RL via DPO-style Training ===')\n",
    "for epoch in range(30):\n",
    "    policy_logits = policy(states)\n",
    "    with torch.no_grad():\n",
    "        ref_logits = ref_policy(states)\n",
    "\n",
    "    policy_logp = F.log_softmax(policy_logits, dim=-1)\n",
    "    ref_logp = F.log_softmax(ref_logits, dim=-1)\n",
    "\n",
    "    chosen_logp = policy_logp.gather(1, chosen_actions.unsqueeze(1)).squeeze(1)\n",
    "    rejected_logp = policy_logp.gather(1, rejected_actions.unsqueeze(1)).squeeze(1)\n",
    "    ref_chosen_logp = ref_logp.gather(1, chosen_actions.unsqueeze(1)).squeeze(1)\n",
    "    ref_rejected_logp = ref_logp.gather(1, rejected_actions.unsqueeze(1)).squeeze(1)\n",
    "\n",
    "    dpo_loss = -F.logsigmoid(\n",
    "        (chosen_logp - ref_chosen_logp) - (rejected_logp - ref_rejected_logp)\n",
    "    ).mean()\n",
    "\n",
    "    optimizer.zero_grad()\n",
    "    dpo_loss.backward()\n",
    "    optimizer.step()\n",
    "\n",
    "    if (epoch+1) % 10 == 0:\n",
    "        with torch.no_grad():\n",
    "            chosen_prob = torch.softmax(policy_logits, dim=-1).gather(1, chosen_actions.unsqueeze(1)).mean()\n",
    "            rejected_prob = torch.softmax(policy_logits, dim=-1).gather(1, rejected_actions.unsqueeze(1)).mean()\n",
    "        print(f'Epoch {epoch+1}: dpo_loss={dpo_loss.item():.4f}, chosen_prob={chosen_prob:.3f}, rejected_prob={rejected_prob:.3f}')\n",
    "\n",
    "print('\\nKey: DPO is an offline RL method - no online sampling needed.')\n",
    "print('It directly optimizes policy on fixed preference data.')"
   ]
  }
