    "## 3. RLHF（基于人类反馈的强化学习）\n",
    "\n",
    "**目的**：将人类偏好转化为奖励信号，使模型行为与人类偏好对齐\n",
    "\n",
    "**基本原理**：RLHF分三步：\n",
    "1. **训练奖励模型**：收集人类偏好排序数据，训练奖励模型学习人类偏好\n",
    "2. **PPO优化策略**：使用奖励模型提供奖励信号，PPO优化语言模型\n",
    "3. "**KL惩罚**：防止策略偏离参考模型过远"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "import torch.nn as nn\n",
    "\n",
    "torch.manual_seed(42)\n",
    "\n",
    "class RewardModel(nn.Module):\n",
    "    def __init__(self, dim=32):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Linear(dim, 64), nn.ReLU(),\n",
    "            nn.Linear(64, 32), nn.ReLU(),\n",
    "            nn.Linear(32, 1)\n",
    "        )\n",
    "    def forward(self, x):\n",
 "        return self.net(x).squeeze(-1)\n",
    "\n",
    "rm = RewardModel()\n",
    "rm_optimizer = torch.optim.Adam(rm.parameters(), lr=1e-3)\n",
    "\n",
    "n_pairs = 200\n",
    "chosen = torch.randn(n_pairs, 32) + 0.5\n",
    "rejected = torch.randn(n_pairs, 32) - 0.5\n",
    "\n",
    "print('=== Step 1: Reward Model Training (Bradley-Terry) ===')\n",
    "for epoch in range(30):\n",
    "    r_chosen = rm(chosen)\n",
    "    r_rejected = rm(rejected)\n",
    "    loss = -torch.log(torch.sigmoid(r_chosen - r_rejected)).mean()\n",
    "    rm_optimizer.zero_grad()\n",
    "    loss.backward()\n",
    "    rm_optimizer.step()\n",
    "    if (epoch+1) % 10 == 0:\n",
    "        acc = (r_chosen > r_rejected).float().mean()\n",
    "        print(f'  Epoch {epoch+1}: loss={loss.item():.4f}, preference_accuracy={acc:.3f}')\n",
    "\n",
    "print('\\n=== Step 2: Use Reward Model to Guide Policy (simplified) ===')\n",
    "class SimpleLLM(nn.Module):\n",
    "    def __init__(self, dim=32, vocab=100):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(nn.Linear(dim, 64), nn.ReLU(), nn.Linear(64, vocab))\n",
    "    def forward(self, x):\n",
    "        return self.net(x)\n",
    "\n",
    "llm = SimpleLLM()\n",
    "ref_llm = SimpleLLM()\n",
    "ref_llm.load_state_dict(llm.state_dict())\n",
    "llm_optimizer = torch.optim.Adam(llm.parameters(), lr=1e-4)\n",
    "\n",
    "for step in range(50):\n",
    "    prompts = torch.randn(16, 32)\n",
    "    with torch.no_grad():\n",
    "        rewards = rm(prompts)\n",
    "    logits = llm(prompts)\n",
    "    log_probs = torch.log_softmax(logits, dim=-1)\n",
    "    selected = log_probs.max(dim=-1)[0]\n",
    "    with torch.no_grad():\n",
    "        ref_logits = ref_llm(prompts)\n",
    "        kl = (torch.softmax(logits, dim=-1) * (log_probs - torch.log_softmax(ref_logits, dim=-1))).sum(dim=-1)\n",
    "    rl_loss = -(rewards * selected).mean() + 0.01 * kl.mean()\n",
    "    llm_optimizer.zero_grad()\n",
    "    rl_loss.backward()\n",
    "    llm_optimizer.step()\n",
    "    if (step+1) % 10 == 0:\n",
    "        print(f'  Step {step+1}: avg_reward={rewards.mean():.3f}, kl={kl.mean():.4f}')\n",
    "\n",
    "print('\\nRLHF Pipeline: RM learns preferences -> PPO optimizes policy against RM -> KL keeps policy close to ref')"
   ]
  },
  {
   "cell_type": "markdown",
