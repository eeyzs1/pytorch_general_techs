    "class LLMBenchmarkRunner:\n",
    "    \"\"\"LLM基准测试运行器 - 测量TTFT、ITL、吞吐、内存\"\"\"\n",
    "    def __init__(self, model, device='cpu', dtype=torch.float32):\n",
    "        self.model = model.to(device).to(dtype).eval()\n",
    "        self.device = device\n",
    "        self.dtype = dtype\n",
    "\n",
    "    def benchmark_prefill(self, input_ids, warmup=3, repeat=10):\n",
    "        \"\"\"测量Prefill阶段 (TTFT)\"\"\"\n",
    "        input_ids = input_ids.to(self.device)\n",
    "\n",
    "        for _ in range(warmup):\n",
    "            with torch.no_grad():\n",
    "                self.model(input_ids, use_cache=True)\n",
    "        if self.device == 'cuda':\n",
    "            torch.cuda.synchronize()\n",
    "\n",
    "        times = []\n",
    "        for _ in range(repeat):\n",
    "            if self.device == 'cuda':\n",
    "                start = torch.cuda.Event(enable_timing=True)\n",
    "                end = torch.cuda.Event(enable_timing=True)\n",
    "                start.record()\n",
    "                with torch.no_grad():\n",
    "                    self.model(input_ids, use_cache=True)\n",
    "                end.record()\n",
    "                torch.cuda.synchronize()\n",
    "                times.append(start.elapsed_time(end))\n",
    "            else:\n",
    "                t0 = time.perf_counter()\n",
    "                with torch.no_grad():\n",
    "                    self.model(input_ids, use_cache=True)\n",
    "                times.append((time.perf_counter() - t0) * 1000)\n",
    "\n",
    "        return {\n",
    "            'ttft_ms': {\n",
    "                'mean': np.mean(times),\n",
    "                'p50': np.percentile(times, 50),\n",
    "                'p90': np.percentile(times, 90),\n",
    "                'p99': np.percentile(times, 99),\n",
    "                'std': np.std(times),\n",
    "            },\n",
    "            'input_tokens': input_ids.shape[1],\n",
    "        }\n",
    "\n",
    "    def benchmark_decode(self, input_ids, n_generate=32, warmup=2, repeat=5):\n",
    "        \"\"\"测量Decode阶段 (ITL和吞吐)\"\"\"\n",
    "        input_ids = input_ids.to(self.device)\n",
    "\n",
    "        all_itl = []\n",
    "        for _ in range(repeat):\n",
    "            with torch.no_grad():\n",
    "                logits, kv_cache = self.model(input_ids, use_cache=True)\n",
    "\n",
    "            next_token = logits[:, -1, :].argmax(dim=-1, keepdim=True)\n",
    "            itl_list = []\n",
    "\n",
    "            for _ in range(n_generate):\n",
    "                if self.device == 'cuda':\n",
    "                    torch.cuda.synchronize()\n",
    "                t0 = time.perf_counter()\n",
    "\n",
    "                with torch.no_grad():\n",
    "                    logits, kv_cache = self.model(next_token, kv_cache=kv_cache, use_cache=True)\n",
    "                next_token = logits[:, -1, :].argmax(dim=-1, keepdim=True)\n",
    "\n",
    "                if self.device == 'cuda':\n",
    "                    torch.cuda.synchronize()\n",
    "                itl_list.append((time.perf_counter() - t0) * 1000)\n",
    "\n",
    "            all_itl.extend(itl_list)\n",
    "\n",
    "        return {\n",
    "            'itl_ms': {\n",
    "                'mean': np.mean(all_itl),\n",
    "                'p50': np.percentile(all_itl, 50),\n",
    "                'p90': np.percentile(all_itl, 90),\n",
    "                'p99': np.percentile(all_itl, 99),\n",
    "                'std': np.std(all_itl),\n",
    "            },\n",
    "            'throughput_tps': 1000.0 / np.percentile(all_itl, 50),\n",
    "            'n_generated': n_generate,\n",
    "        }\n",
    "\n",
    "    def measure_memory(self, input_ids, n_generate=32):\n",
    "        \"\"\"测量推理内存占用\"\"\"\n",
    "        if self.device == 'cuda':\n",
    "            torch.cuda.reset_peak_memory_stats()\n",
    "            torch.cuda.empty_cache()\n",
    "            start_mem = torch.cuda.memory_allocated() / 1e6\n",
    "\n",
    "            with torch.no_grad():\n",
    "                logits, kv_cache = self.model(input_ids.to(self.device), use_cache=True)\n",
    "                next_token = logits[:, -1, :].argmax(dim=-1, keepdim=True)\n",
    "                for _ in range(n_generate):\n",
    "                    logits, kv_cache = self.model(next_token, kv_cache=kv_cache, use_cache=True)\n",
    "                    next_token = logits[:, -1, :].argmax(dim=-1, keepdim=True)\n",
    "\n",
    "            peak_mem = torch.cuda.max_memory_allocated() / 1e6\n",
    "            return {'peak_mb': peak_mem, 'model_mb': start_mem}\n",
    "        else:\n",
    "            import sys\n",
    "            model_size = sum(p.numel() * p.element_size() for p in self.model.parameters()) / 1e6\n",
    "            kv_size = 2 * self.model.n_layers * input_ids.shape[1] * self.model.hidden_dim * 4 / 1e6\n",
    "            return {'peak_mb': model_size + kv_size, 'model_mb': model_size, 'kv_mb': kv_size}\n",
    "\n",
    "runner = LLMBenchmarkRunner(model, device=device, dtype=torch.float16 if device == 'cuda' else torch.float32)\n",
    "\n",
    "input_ids = torch.randint(0, 32000, (1, 128))\n",
    "\n",
    "print(\"=== Prefill基准测试 ===\")\n",
    "prefill_result = runner.benchmark_prefill(input_ids, warmup=2, repeat=10)\n",
    "ttft = prefill_result['ttft_ms']\n",
    "print(f\"输入长度: {prefill_result['input_tokens']} tokens\")\n",
    "print(f\"TTFT: mean={ttft['mean']:.2f}ms, P50={ttft['p50']:.2f}ms, P90={ttft['p90']:.2f}ms, P99={ttft['p99']:.2f}ms\")\n",
    "\n",
    "print(f\"\\n=== Decode基准测试 ===\")\n",
    "decode_result = runner.benchmark_decode(input_ids, n_generate=32, warmup=1, repeat=3)\n",
    "itl = decode_result['itl_ms']\n",
    "print(f\"生成token数: {decode_result['n_generated']}\")\n",
    "print(f\"ITL: mean={itl['mean']:.2f}ms, P50={itl['p50']:.2f}ms, P90={itl['p90']:.2f}ms, P99={itl['p99']:.2f}ms\")\n",
    "print(f\"吞吐: {decode_result['throughput_tps']:.1f} tok/s (基于P50 ITL)\")\n",
    "\n",
    "print(f\"\\n=== 内存测量 ===\")\n",
    "mem = runner.measure_memory(input_ids, n_generate=32)\n",
    "print(f\"模型大小: {mem['model_mb']:.1f} MB\")\n",
    "print(f\"峰值内存: {mem['peak_mb']:.1f} MB\")\n",
    "if 'kv_mb' in mem:\n",
    "    print(f\"KV Cache: {mem['kv_mb']:.1f} MB\")"
   ]
