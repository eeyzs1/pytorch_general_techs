    "---\n",
    "## 5.4.3 实际Micro-benchmark：GEMM与Attention性能测量\n",
    "\n",
    "微基准测试是基准测试体系的基础，通过测量核心算子的实际性能，确定硬件的Roofline参数。下面用实际PyTorch代码测量GEMM和Attention的峰值性能。\n",
    "\n",
    "### GEMM微基准\n",
    "\n",
    "矩阵乘法是LLM推理的核心算子，其性能直接决定整体推理速度。通过测量不同尺寸的GEMM，可以确定：\n",
    "- **实际峰值FLOPS**：与标称值的比值（通常30-70%）\n",
    "- **带宽利用率**：实际带宽与理论带宽的比值\n",
    "- **拐点位置**：从memory-bound到compute-bound的转折点"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@contextmanager\n",
    "def torch_timer(label='', warmup=3, repeat=10, device='cpu'):\n",
    "    \"\"\"PyTorch精确计时器 - 支持CUDA event计时\"\"\"\n",
    "    times = []\n",
    "    yield times\n",
    "    if times and label:\n",
    "        arr = np.array(times)\n",
    "        print(f\"  {label}: mean={arr.mean()*1000:.3f}ms, \"\n",
    "              f\"P50={np.percentile(arr,50)*1000:.3f}ms, \"\n",
    "              f\"P99={np.percentile(arr,99)*1000:.3f}ms, \"\n",
    "              f\"std={arr.std()*1000:.3f}ms\")\n",
    "\n",
    "def benchmark_gemm(M, N, K, dtype=torch.float16, device='cpu', warmup=5, repeat=20):\n",
    "    \"\"\"实际GEMM微基准测试\"\"\"\n",
    "    a = torch.randn(M, K, dtype=dtype, device=device)\n",
    "    b = torch.randn(K, N, dtype=dtype, device=device)\n",
    "\n",
    "    for _ in range(warmup):\n",
    "        _ = torch.mm(a, b)\n",
    "    if device == 'cuda':\n",
    "        torch.cuda.synchronize()\n",
    "\n",
    "    times = []\n",
    "    for _ in range(repeat):\n",
    "        if device == 'cuda':\n",
    "            start = torch.cuda.Event(enable_timing=True)\n",
    "            end = torch.cuda.Event(enable_timing=True)\n",
    "            start.record()\n",
    "            _ = torch.mm(a, b)\n",
    "            end.record()\n",
    "            torch.cuda.synchronize()\n",
    "            times.append(start.elapsed_time(end) / 1000.0)\n",
    "        else:\n",
    "            t0 = time.perf_counter()\n",
    "            _ = torch.mm(a, b)\n",
    "            times.append(time.perf_counter() - t0)\n",
    "\n",
    "    flops = 2.0 * M * N * K\n",
    "    bytes_accessed = (M * K + K * N + M * N) * dtype.itemsize\n",
    "    avg_time = np.percentile(times, 50)\n",
    "    achieved_tflops = flops / avg_time / 1e12\n",
    "    achieved_bw_gbs = bytes_accessed / avg_time / 1e9\n",
    "    arithmetic_intensity = flops / bytes_accessed\n",
    "\n",
    "    return {\n",
    "        'M': M, 'N': N, 'K': K,\n",
    "        'time_ms': avg_time * 1000,\n",
    "        'tflops': achieved_tflops,\n",
    "        'bandwidth_gbs': achieved_bw_gbs,\n",
    "        'arithmetic_intensity': arithmetic_intensity,\n",
    "        'flops': flops,\n",
    "        'bytes': bytes_accessed,\n",
    "    }\n",
    "\n",
    "device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "dtype = torch.float16\n",
    "\n",
    "print(f\"=== GEMM微基准测试 (device={device}, dtype={dtype}) ===\")\n",
    "print(f\"\\n{'M':<8} {'N':<8} {'K':<8} {'时间(ms)':<12} {'TFLOPS':<10} {'BW(GB/s)':<10} {'AI(FLOP/B)':<12} {'瓶颈'}\")\n",
    "print(\"-\" * 80)\n",
    "\n",
    "gemm_results = []\n",
    "test_sizes = [\n",
    "    (1, 4096, 4096),\n",
    "    (4, 4096, 4096),\n",
    "    (32, 4096, 4096),\n",
    "    (128, 4096, 4096),\n",
    "    (512, 4096, 4096),\n",
    "    (1, 14336, 4096),\n",
    "    (128, 14336, 4096),\n",
    "]\n",
    "\n",
    "for M, N, K in test_sizes:\n",
    "    r = benchmark_gemm(M, N, K, dtype=dtype, device=device)\n",
    "    gemm_results.append(r)\n",
    "    ai = r['arithmetic_intensity']\n",
    "    bottleneck = 'compute' if ai > 50 else 'memory'\n",
    "    print(f\"{M:<8} {N:<8} {K:<8} {r['time_ms']:<12.3f} {r['tflops']:<10.2f} {r['bandwidth_gbs']:<10.1f} {ai:<12.1f} {bottleneck}\")\n",
    "\n",
    "print(f\"\\n=== 关键洞察 ===\")\n",
    "decode_r = gemm_results[0]\n",
    "prefill_r = gemm_results[4]\n",
