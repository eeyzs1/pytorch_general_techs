    "---\n",
    "## 5.4.12 基准测试自动化与CI/CD集成\n",
    "\n",
    "产业级部署必须将基准测试自动化，集成到CI/CD流水线中，防止性能回归。\n",
    "\n",
    "### 自动化基准测试流水线\n",
    "\n",
    "```\n",
    "代码提交 → 触发CI → 自动基准测试 → 与基线对比 → 通过/告警\n",
    "                                      ↓\n",
    "                              性能回归? → 阻止合并\n",
    "                              性能提升? → 更新基线\n",
    "```\n",
    "\n",
    "### 性能回归检测规则\n",
    "\n",
    "| 指标 | 回归阈值 | 动作 |\n",
    "|------|---------|------|\n",
    "| TTFT | 增加>20% | 阻止合并 |\n",
    "| ITL | 增加>15% | 阻止合并 |\n",
    "| 吞吐 | 下降>15% | 阻止合并 |\n",
    "| 内存峰值 | 增加>10% | 警告 |\n",
    "| 功耗 | 增加>20% | 警告 |\n",
    "| P99延迟 | 增加>25% | 阻止合并 |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class BenchmarkCI:\n",
    "    \"\"\"基准测试CI/CD集成\"\"\"\n",
    "    REGRESSION_THRESHOLDS = {\n",
    "        'ttft_ms': 0.20,\n",
    "        'itl_ms': 0.15,\n",
    "        'throughput_tps': -0.15,\n",
    "        'memory_peak_mb': 0.10,\n",
    "        'power_avg_w': 0.20,\n",
    "    }\n",
    "\n",
    "    def __init__(self, baseline_report):\n",
    "        self.baseline = baseline_report\n",
    "\n",
    "    def check_regression(self, current_report):\n",
    "        \"\"\"检测性能回归\"\"\"\n",
    "        regressions = []\n",
    "        improvements = []\n",
    "\n",
    "        metrics = {\n",
    "            'ttft_ms': (self.baseline['ttft']['p50'], current_report['ttft']['p50']),\n",
    "            'itl_ms': (self.baseline['itl']['p50'], current_report['itl']['p50']),\n",
    "            'throughput_tps': (self.baseline['throughput_tps'], current_report['throughput_tps']),\n",
    "            'memory_peak_mb': (self.baseline['memory_peak_mb'], current_report['memory_peak_mb']),\n",
    "            'power_avg_w': (self.baseline['power_avg_w'], current_report['power_avg_w']),\n",
    "        }\n",
    "\n",
    "        for metric, (baseline_val, current_val) in metrics.items():\n",
    "            if baseline_val == 0:\n",
    "                continue\n",
    "            change = (current_val - baseline_val) / baseline_val\n",
    "            threshold = self.REGRESSION_THRESHOLDS[metric]\n",
    "\n",
    "            if metric == 'throughput_tps':\n",
    "                is_regression = change < threshold\n",
    "                is_improvement = change > abs(threshold)\n",
    "            else:\n",
    "                is_regression = change > threshold\n",
    "                is_improvement = change < -abs(threshold)\n",
    "\n",
    "            if is_regression:\n",
    "                regressions.append({\n",
    "                    'metric': metric,\n",
    "                    'baseline': baseline_val,\n",
    "                    'current': current_val,\n",
    "                    'change_pct': change * 100,\n",
    "                    'threshold_pct': threshold * 100,\n",
    "                })\n",
    "            elif is_improvement:\n",
    "                improvements.append({\n",
    "                    'metric': metric,\n",
    "                    'baseline': baseline_val,\n",
    "                    'current': current_val,\n",
    "                    'change_pct': change * 100,\n",
    "                })\n",
    "\n",
    "        return regressions, improvements\n",
    "\n",
    "baseline = {\n",
    "    'ttft': {'p50': 250, 'p90': 280, 'p99': 320},\n",
    "    'itl': {'p50': 45, 'p90': 55, 'p99': 70},\n",
    "    'throughput_tps': 22.2,\n",
    "    'memory_peak_mb': 2800,\n",
    "    'power_avg_w': 4.5,\n",
    "}\n",
    "\n",
    "ci = BenchmarkCI(baseline)\n",
    "\n",
    "test_scenarios = [\n",
    "    ('正常更新', {\n",
    "        'ttft': {'p50': 255, 'p90': 285, 'p99': 325},\n",
    "        'itl': {'p50': 46, 'p90': 56, 'p99': 71},\n",
    "        'throughput_tps': 21.7,\n",
    "        'memory_peak_mb': 2850,\n",
    "        'power_avg_w': 4.6,\n",
    "    }),\n",
    "    ('性能回归', {\n",
    "        'ttft': {'p50': 310, 'p90': 350, 'p99': 400},\n",
    "        'itl': {'p50': 55, 'p90': 65, 'p99': 80},\n",
    "        'throughput_tps': 18.2,\n",
    "        'memory_peak_mb': 2900,\n",
    "        'power_avg_w': 4.7,\n",
    "    }),\n",
    "    ('性能提升', {\n",
    "        'ttft': {'p50': 220, 'p90': 245, 'p99': 280},\n",
    "        'itl': {'p50': 38, 'p90': 45, 'p99': 55},\n",
    "        'throughput_tps': 26.3,\n",
    "        'memory_peak_mb': 2750,\n",
    "        'power_avg_w': 4.3,\n",
    "    }),\n",
    "]\n",
    "\n",
    "print(\"=== CI/CD性能回归检测 ===\")\n",
    "for name, current in test_scenarios:\n",
    "    regressions, improvements = ci.check_regression(current)\n",
    "    print(f\"\\n--- {name} ---\")\n",
    "    if regressions:\n",
    "        print(f\"  ⚠ 性能回归:\")\n",
    "        for r in regressions:\n",
    "            print(f\"    {r['metric']}: {r['baseline']:.1f} → {r['current']:.1f} ({r['change_pct']:+.1f}%, 阈值{r['threshold_pct']:.0f}%)\")\n",
    "        print(f\"  → 阻止合并!\")\n",
    "    else:\n",
    "        print(f\"  ✓ 无性能回归\")\n",
    "    if improvements:\n",
    "        print(f\"  🎉 性能提升:\")\n",
    "        for imp in improvements:\n",
    "            print(f\"    {imp['metric']}: {imp['baseline']:.1f} → {imp['current']:.1f} ({imp['change_pct']:+.1f}%)\")\n",
    "\n",
    "print(f\"\\n=== CI/CD集成要点 ===\")\n",
    "print(f\"1. 每次模型/框架更新自动跑benchmark, 与基线对比\")\n",
    "print(f\"2. 性能回归超阈值自动阻止合并, 防止性能退化\")\n",
    "print(f\"3. 性能提升自动更新基线, 持续优化\")\n",
    "print(f\"4. 多设备并行测试, 缩短CI时间\")\n",
    "print(f\"5. 历史数据追踪, 发现长期性能趋势\")\n",
    "print(f\"6. 报告P99而非平均, 用户体验由长尾决定\")"
   ]
  },
