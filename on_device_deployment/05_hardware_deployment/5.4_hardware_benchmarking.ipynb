    "---\n",
    "## 5.4.4 实际Attention微基准\n",
    "\n",
    "Attention是LLM推理中除GEMM外最关键的算子。其性能特征与GEMM不同：\n",
    "- **Prefill阶段**：$O(L^2)$计算量，compute-bound\n",
    "- **Decode阶段**：$O(L)$计算量但需读取全部KV Cache，memory-bound"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def benchmark_attention(batch, seq_len, n_heads, head_dim, dtype=torch.float16,\n",
    "                         device='cpu', warmup=5, repeat=20, is_decode=False):\n",
    "    \"\"\"实际Attention微基准测试\"\"\"\n",
    "    hidden_dim = n_heads * head_dim\n",
    "    q = torch.randn(batch, n_heads, seq_len if not is_decode else 1, head_dim, dtype=dtype, device=device)\n",
    "    k = torch.randn(batch, n_heads, seq_len, head_dim, dtype=dtype, device=device)\n",
    "    v = torch.randn(batch, n_heads, seq_len, head_dim, dtype=dtype, device=device)\n",
    "\n",
    "    def run_attn():\n",
    "        scale = head_dim ** -0.5\n",
    "        scores = torch.matmul(q, k.transpose(-2, -1)) * scale\n",
    "        attn_weights = F.softmax(scores, dim=-1)\n",
    "        output = torch.matmul(attn_weights, v)\n",
    "        return output\n",
    "\n",
    "    for _ in range(warmup):\n",
    "        _ = run_attn()\n",
    "    if device == 'cuda':\n",
    "        torch.cuda.synchronize()\n",
    "\n",
    "    times = []\n",
    "    for _ in range(repeat):\n",
    "        if device == 'cuda':\n",
    "            start = torch.cuda.Event(enable_timing=True)\n",
    "            end = torch.cuda.Event(enable_timing=True)\n",
    "            start.record()\n",
    "            _ = run_attn()\n",
    "            end.record()\n",
    "            torch.cuda.synchronize()\n",
    "            times.append(start.elapsed_time(end) / 1000.0)\n",
    "        else:\n",
    "            t0 = time.perf_counter()\n",
    "            _ = run_attn()\n",
    "            times.append(time.perf_counter() - t0)\n",
    "\n",
    "    q_len = 1 if is_decode else seq_len\n",
    "    flops = 2 * batch * n_heads * q_len * seq_len * head_dim\n",
    "    kv_bytes = 2 * batch * n_heads * seq_len * head_dim * dtype.itemsize\n",
    "    q_bytes = batch * n_heads * q_len * head_dim * dtype.itemsize\n",
    "    score_bytes = batch * n_heads * q_len * seq_len * dtype.itemsize\n",
    "    total_bytes = q_bytes + kv_bytes + score_bytes\n",
    "\n",
    "    avg_time = np.percentile(times, 50)\n",
    "    return {\n",
    "        'phase': 'decode' if is_decode else 'prefill',\n",
    "        'batch': batch, 'seq_len': seq_len, 'n_heads': n_heads, 'head_dim': head_dim,\n",
    "        'time_ms': avg_time * 1000,\n",
    "        'tflops': flops / avg_time / 1e12,\n",
    "        'bandwidth_gbs': total_bytes / avg_time / 1e9,\n",
    "        'arithmetic_intensity': flops / total_bytes,\n",
    "        'flops': flops, 'bytes': total_bytes,\n",
    "    }\n",
    "\n",
    "print(f\"=== Attention微基准测试 (device={device}, dtype={dtype}) ===\")\n",
    "print(f\"\\n--- Prefill阶段 ---\")\n",
    "print(f\"{'B':<4} {'L':<6} {'H':<4} {'d':<4} {'时间(ms)':<12} {'TFLOPS':<10} {'BW(GB/s)':<10} {'AI':<10} {'瓶颈'}\")\n",
    "print(\"-\" * 70)\n",
    "\n",
    "attn_configs = [\n",
    "    (1, 128, 32, 128, False),\n",
    "    (1, 512, 32, 128, False),\n",
    "    (1, 2048, 32, 128, False),\n",
    "    (4, 512, 32, 128, False),\n",
    "]\n",
    "for b, l, h, d, dec in attn_configs:\n",
    "    r = benchmark_attention(b, l, h, d, dtype=dtype, device=device, is_decode=dec)\n",
    "    bottleneck = 'compute' if r['arithmetic_intensity'] > 50 else 'memory'\n",
    "    print(f\"{b:<4} {l:<6} {h:<4} {d:<4} {r['time_ms']:<12.3f} {r['tflops']:<10.2f} {r['bandwidth_gbs']:<10.1f} {r['arithmetic_intensity']:<10.1f} {bottleneck}\")\n",
    "\n",
    "print(f\"\\n--- Decode阶段 ---\")\n",
    "decode_configs = [\n",
    "    (1, 128, 32, 128, True),\n",
    "    (1, 512, 32, 128, True),\n",
    "    (1, 2048, 32, 128, True),\n",
    "    (1, 4096, 32, 128, True),\n",
    "]\n",
    "for b, l, h, d, dec in decode_configs:\n",
    "    r = benchmark_attention(b, l, h, d, dtype=dtype, device=device, is_decode=dec)\n",
    "    bottleneck = 'compute' if r['arithmetic_intensity'] > 50 else 'memory'\n",
    "    print(f\"{b:<4} {l:<6} {h:<4} {d:<4} {r['time_ms']:<12.3f} {r['tflops']:<10.2f} {r['bandwidth_gbs']:<10.1f} {r['arithmetic_intensity']:<10.1f} {bottleneck}\")\n",
    "\n",
    "print(f\"\\n=== 关键洞察 ===\")\n",
    "print(f\"1. Prefill: 随seq_len增长, 计算量O(L²)增长, 逐渐变为compute-bound\")\n",
    "print(f\"2. Decode: 计算量O(L), 但需读取全部KV Cache, 始终memory-bound\")\n",
    "print(f\"3. Decode的TFLOPS远低于Prefill → MAC利用率极低, 量化减少搬运量最有效\")\n",
    "print(f\"4. GQA(减少KV头数)直接降低Decode的KV读取量, 是端侧必备优化\")"
   ]
