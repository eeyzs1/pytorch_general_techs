    "---\n",
    "## 5.4.11 跨硬件性能对比分析\n",
    "\n",
    "产业级部署通常需要支持多种硬件平台，跨硬件对比分析帮助确定最优部署策略。\n",
    "\n",
    "### 对比分析的关键原则\n",
    "\n",
    "1. **统一量化配置**：所有硬件使用相同的量化精度对比\n",
    "2. **统一模型版本**：使用同一模型checkpoint\n",
    "3. **统一测试条件**：相同的输入长度、生成长度、batch大小\n",
    "4. **报告持续性能**：基于30分钟压力测试的稳态性能\n",
    "5. **报告P99延迟**：用户体验由长尾决定"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class CrossHardwareComparator:\n",
    "    \"\"\"跨硬件性能对比分析器\"\"\"\n",
    "    def __init__(self, candidates: List[HardwareCandidate]):\n",
    "        self.candidates = candidates\n",
    "\n",
    "    def compare_for_model(self, model_params_b, quant_bits=4, seq_len=512):\n",
    "        \"\"\"对比所有硬件对特定模型的支持能力\"\"\"\n",
    "        comparisons = []\n",
    "        for hw in self.candidates:\n",
    "            suite = BenchmarkSuite(hw)\n",
    "            model_result = suite.model_benchmark(model_params_b, seq_len, quant_bits)\n",
    "            stress = suite.stress_benchmark(model_params_b)\n",
    "            thermal = ThermalThrottleSimulator(hw.npu_tdp_watts)\n",
    "\n",
    "            if not model_result['feasible']:\n",
    "                comparisons.append({\n",
    "                    'hardware': hw.name, 'category': hw.category,\n",
    "                    'feasible': False, 'reason': model_result['reason']\n",
    "                })\n",
    "                continue\n",
    "\n",
    "            sustained_tps = model_result['decode_tps'] * stress['sustained_tps_ratio']\n",
    "            comparisons.append({\n",
    "                'hardware': hw.name,\n",
    "                'category': hw.category,\n",
    "                'feasible': True,\n",
    "                'decode_tps': model_result['decode_tps'],\n",
    "                'sustained_tps': sustained_tps,\n",
    "                'ttft_ms': model_result['ttft_ms'],\n",
    "                'model_size_mb': model_result['model_size_mb'],\n",
    "                'power_w': hw.npu_tdp_watts,\n",
    "                'efficiency_tps_per_w': sustained_tps / hw.npu_tdp_watts,\n",
    "                'thermal_throttle_pct': stress['thermal_throttle_pct'],\n",
    "                'time_to_throttle_s': thermal.time_to_throttle(),\n",
    "                'sdk_maturity': hw.sdk_maturity,\n",
    "                'cost_usd': hw.hardware_cost_usd,\n",
    "            })\n",
    "        return comparisons\n",
    "\n",
    "comparator = CrossHardwareComparator(CANDIDATES)\n",
    "\n",
    "for model_name, params_b in [('Qwen2.5-1.5B', 1.5), ('Qwen2.5-3B', 3), ('Qwen2.5-7B', 7)]:\n",
    "    print(f\"\\n{'='*100}\")\n",
    "    print(f\"  {model_name} (INT4) 跨硬件对比\")\n",
    "    print(f\"{'='*100}\")\n",
    "    comparisons = comparator.compare_for_model(params_b, quant_bits=4)\n",
    "\n",
    "    feasible = [c for c in comparisons if c['feasible']]\n",
    "    infeasible = [c for c in comparisons if not c['feasible']]\n",
    "\n",
    "    print(f\"\\n{'硬件':<22} {'类别':<15} {'Decode':<10} {'持续':<10} {'TTFT':<10} {'功耗':<8} {'能效':<10} {'降频':<8} {'成本'}\")\n",
    "    print(\"-\" * 103)\n",
    "    for c in feasible:\n",
    "        print(f\"{c['hardware']:<22} {c['category']:<15} {c['decode_tps']:<10.1f} \"\n",
    "              f\"{c['sustained_tps']:<10.1f} {c['ttft_ms']:<10.0f} {c['power_w']:<8.1f} \"\n",
    "              f\"{c['efficiency_tps_per_w']:<10.2f} {c['thermal_throttle_pct']:<8.0f}% ${c['cost_usd']}\")\n",
    "\n",
    "    if infeasible:\n",
    "        print(f\"\\n不可行:\")\n",
    "        for c in infeasible:\n",
    "            print(f\"  {c['hardware']}: {c['reason']}\")\n",
    "\n",
    "print(f\"\\n=== 跨硬件对比关键洞察 ===\")\n",
    "print(f\"1. 1.5B模型: 几乎所有端侧硬件都可部署, 是最安全的选型\")\n",
    "print(f\"2. 3B模型: 旗舰手机和边缘设备可部署, 中端手机需INT4量化\")\n",
    "print(f\"3. 7B模型: 仅旗舰手机(12GB+)和边缘设备可部署, 需INT4量化\")\n",
    "print(f\"4. 能效比(toks/W)是移动端的关键指标, NPU远优于CPU\")\n",
    "print(f\"5. 持续性能vs峰值性能的差距在手机上可达30-50%\")"
   ]
