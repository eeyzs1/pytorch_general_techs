    "---\n",
    "## 5.4.5 模型级基准测试：实际LLM推理性能测量\n",
    "\n",
    "模型级基准测试测量完整LLM推理的端到端性能，是最贴近实际使用场景的测试。下面实现一个可复用的LLM基准测试框架。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class MiniLLM(nn.Module):\n",
    "    \"\"\"迷你LLM用于基准测试 - 模拟真实LLM的计算特征\"\"\"\n",
    "    def __init__(self, hidden_dim=512, n_layers=4, n_heads=8, ffn_mult=4):\n",
    "        super().__init__()\n",
    "        self.hidden_dim = hidden_dim\n",
    "        self.n_layers = n_layers\n",
    "        self.n_heads = n_heads\n",
    "        self.head_dim = hidden_dim // n_heads\n",
    "        self.ffn_dim = hidden_dim * ffn_mult\n",
    "\n",
    "        self.embed = nn.Embedding(32000, hidden_dim)\n",
    "        self.layers = nn.ModuleList()\n",
    "        for _ in range(n_layers):\n",
    "            self.layers.append(nn.ModuleDict({\n",
    "                'q_proj': nn.Linear(hidden_dim, hidden_dim, bias=False),\n",
    "                'k_proj': nn.Linear(hidden_dim, hidden_dim, bias=False),\n",
    "                'v_proj': nn.Linear(hidden_dim, hidden_dim, bias=False),\n",
    "                'o_proj': nn.Linear(hidden_dim, hidden_dim, bias=False),\n",
    "                'gate_proj': nn.Linear(hidden_dim, self.ffn_dim, bias=False),\n",
    "                'up_proj': nn.Linear(hidden_dim, self.ffn_dim, bias=False),\n",
    "                'down_proj': nn.Linear(self.ffn_dim, hidden_dim, bias=False),\n",
    "                'input_layernorm': nn.LayerNorm(hidden_dim),\n",
    "                'post_attention_layernorm': nn.LayerNorm(hidden_dim),\n",
    "            }))\n",
    "        self.lm_head = nn.Linear(hidden_dim, 32000, bias=False)\n",
    "\n",
    "    def forward(self, input_ids, kv_cache=None, use_cache=False):\n",
    "        B, L = input_ids.shape\n",
    "        h = self.embed(input_ids)\n",
    "\n",
    "        new_kv_cache = [] if use_cache else None\n",
    "        for i, layer in enumerate(self.layers):\n",
    "            residual = h\n",
    "            h = layer['input_layernorm'](h)\n",
    "\n",
    "            q = layer['q_proj'](h)\n",
    "            k = layer['k_proj'](h)\n",
    "            v = layer['v_proj'](h)\n",
    "\n",
    "            q = q.view(B, L, self.n_heads, self.head_dim).transpose(1, 2)\n",
    "            k = k.view(B, L, self.n_heads, self.head_dim).transpose(1, 2)\n",
    "            v = v.view(B, L, self.n_heads, self.head_dim).transpose(1, 2)\n",
    "\n",
    "            if kv_cache is not None and i < len(kv_cache):\n",
    "                prev_k, prev_v = kv_cache[i]\n",
    "                k = torch.cat([prev_k, k], dim=2)\n",
    "                v = torch.cat([prev_v, v], dim=2)\n",
    "\n",
    "            if use_cache:\n",
    "                new_kv_cache.append((k, v))\n",
    "\n",
    "            scale = self.head_dim ** -0.5\n",
    "            attn = torch.matmul(q, k.transpose(-2, -1)) * scale\n",
    "            attn = F.softmax(attn, dim=-1)\n",
    "            h = torch.matmul(attn, v)\n",
    "            h = h.transpose(1, 2).contiguous().view(B, L, -1)\n",
    "            h = layer['o_proj'](h)\n",
    "            h = residual + h\n",
    "\n",
    "            residual = h\n",
    "            h = layer['post_attention_layernorm'](h)\n",
    "            gate = F.silu(layer['gate_proj'](h))\n",
    "            up = layer['up_proj'](h)\n",
    "            h = layer['down_proj'](gate * up)\n",
    "            h = residual + h\n",
    "\n",
    "        logits = self.lm_head(h)\n",
    "        return logits, new_kv_cache\n",
    "\n",
    "model = MiniLLM(hidden_dim=512, n_layers=4, n_heads=8)\n",
    "total_params = sum(p.numel() for p in model.parameters())\n",
    "model_size_mb = sum(p.numel() * p.element_size() for p in model.parameters()) / 1e6\n",
    "print(f\"MiniLLM: {total_params/1e6:.1f}M参数, {model_size_mb:.1f}MB (FP32)\")\n",
    "model.eval()"
   ]
  },
