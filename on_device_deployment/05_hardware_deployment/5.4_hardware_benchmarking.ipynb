    "@dataclass\n",
    "class SupplyChainRisk:\n",
    "    vendor: str\n",
    "    capacity_score: int\n",
    "    sanction_risk: int\n",
    "    sdk_stability: int\n",
    "    long_term_support: int\n",
    "    alternative_available: int\n",
    "    ecosystem_maturity: int\n",
    "\n",
    "    @property\n",
    "    def overall_risk(self):\n",
    "        scores = [self.capacity_score, self.sanction_risk, self.sdk_stability,\n",
    "                  self.long_term_support, self.alternative_available, self.ecosystem_maturity]\n",
    "        return sum(scores) / len(scores)\n",
    "\n",
    "    @property\n",
    "    def risk_level(self):\n",
    "        avg = self.overall_risk\n",
    "        if avg >= 4:\n",
    "            return '低风险'\n",
    "        elif avg >= 3:\n",
    "            return '中风险'\n",
    "        else:\n",
    "            return '高风险'\n",
    "\n",
    "risks = [\n",
    "    SupplyChainRisk('Qualcomm', 5, 3, 4, 4, 3, 5),\n",
    "    SupplyChainRisk('Apple', 5, 2, 5, 5, 1, 5),\n",
    "    SupplyChainRisk('MediaTek', 4, 4, 3, 3, 3, 3),\n",
    "    SupplyChainRisk('Huawei', 3, 1, 3, 3, 2, 2),\n",
    "    SupplyChainRisk('NVIDIA', 4, 2, 5, 5, 2, 5),\n",
    "    SupplyChainRisk('Rockchip', 3, 5, 2, 2, 3, 1),\n",
    "]\n",
    "\n",
    "print(\"=== 供应链风险评估 (1-5分, 5=最好/最低风险) ===\")\n",
