    "---\n",
    "## 5.4.6 量化对性能的影响：实测对比\n",
    "\n",
    "量化是端侧部署最关键的优化，下面通过实际代码测量不同量化配置对推理性能的影响。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def apply_dynamic_quantization(model):\n",
    "    \"\"\"应用PyTorch动态量化 (INT8权重)\"\"\"\n",
    "    quantized_model = torch.quantization.quantize_dynamic(\n",
    "        model,\n",
    "        {nn.Linear},\n",
    "        dtype=torch.qint8\n",
    "    )\n",
    "    return quantized_model\n",
    "\n",
    "def measure_model_size(model):\n",
    "    \"\"\"测量模型实际内存占用\"\"\"\n",
    "    total_bytes = 0\n",
    "    for param in model.parameters():\n",
    "        total_bytes += param.numel() * param.element_size()\n",
    "    for buf in model.buffers():\n",
    "        total_bytes += buf.numel() * buf.element_size()\n",
    "    return total_bytes / 1e6\n",
    "\n",
    "def simulate_int4_quantization(weight, group_size=128):\n",
    "    \"\"\"模拟INT4量化对权重的影响\"\"\"\n",
    "    orig_shape = weight.shape\n",
    "    w = weight.flatten()\n",
    "    n_groups = w.numel() // group_size\n",
    "    w_grouped = w[:n_groups * group_size].reshape(n_groups, group_size)\n",
    "    scale = w_grouped.abs().amax(dim=1, keepdim=True) / 7.0\n",
    "    scale = torch.clamp(scale, min=1e-8)\n",
    "    w_q = torch.clamp(torch.round(w_grouped / scale), -8, 7)\n",
    "    w_deq = (w_q * scale).flatten()\n",
    "    padded = torch.zeros_like(w)\n",
    "    padded[:w_deq.numel()] = w_deq\n",
    "    return padded.reshape(orig_shape)\n",
    "\n",
    "fp32_model = MiniLLM(hidden_dim=512, n_layers=4, n_heads=8).eval()\n",
    "fp16_model = MiniLLM(hidden_dim=512, n_layers=4, n_heads=8).half().eval()\n",
    "fp16_model.load_state_dict({k: v.half() for k, v in fp32_model.state_dict().items()})\n",
    "\n",
    "fp32_size = measure_model_size(fp32_model)\n",
    "fp16_size = measure_model_size(fp16_model)\n",
    "\n",
    "int4_weight_size = fp32_size / 8\n",
    "\n",
    "print(\"=== 量化对模型大小的影响 ===\")\n",
    "print(f\"FP32: {fp32_size:.1f} MB\")\n",
    "print(f\"FP16: {fp16_size:.1f} MB ({fp32_size/fp16_size:.1f}x压缩)\")\n",
    "print(f\"INT4 (估算): {int4_weight_size:.1f} MB ({fp32_size/int4_weight_size:.1f}x压缩)\")\n",
    "\n",
    "print(f\"\\n=== 量化精度影响分析 ===\")\n",
    "test_weight = torch.randn(512, 512)\n",
    "deq_weight = simulate_int4_quantization(test_weight, group_size=128)\n",
    "mse = F.mse_loss(test_weight, deq_weight)\n",
    "cos_sim = F.cosine_similarity(test_weight.flatten().unsqueeze(0),\n",
    "                                deq_weight.flatten().unsqueeze(0))\n",
    "print(f\"INT4量化MSE: {mse:.6f}\")\n",
    "print(f\"INT4量化余弦相似度: {cos_sim.item():.6f}\")\n",
    "\n",
    "print(f\"\\n=== 不同量化配置的预期性能对比 ===\")\n",
    "configs = [\n",
    "    ('FP32', 4, 1.0, '基线, 最高精度'),\n",
    "    ('FP16', 2, 1.8, '精度几乎无损, 速度提升1.5-2x'),\n",
    "    ('INT8 动态量化', 1, 2.5, '权重INT8, 激活FP32, 精度损失小'),\n",
    "    ('INT4 (W4A16)', 0.5, 3.5, '权重INT4, 激活FP16, 端侧首选'),\n",
    "    ('INT4+KV INT4', 0.5, 4.0, '权重+KV Cache均INT4, 最大压缩'),\n",
    "]\n",
    "print(f\"\\n{'配置':<18} {'字节/参数':<10} {'预期加速':<10} {'说明'}\")\n",
    "print(\"-\" * 60)\n",
    "for name, bpw, speedup, desc in configs:\n",
    "    print(f\"{name:<18} {bpw:<10.1f} {speedup:<10.1f}x {desc}\")\n",
    "\n",
    "print(f\"\\n=== 产业实践要点 ===\")\n",
    "print(f\"1. FP16是精度安全的底线, 几乎所有场景都应使用FP16而非FP32\")\n",
    "print(f\"2. INT8动态量化是CPU推理的最佳平衡, PyTorch原生支持\")\n",
    "print(f\"3. INT4(W4A16)是端侧NPU推理的首选, 需要专用量化工具\")\n",
