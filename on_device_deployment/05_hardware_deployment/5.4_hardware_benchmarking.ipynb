    "---\n",
    "## 5.4.7 热节流与持续性能测试\n",
    "\n",
    "端侧设备100%会遇到热节流问题。短时间基准测试的性能数据不能代表持续推理的实际性能。必须进行长时间压力测试来测量热节流后的稳态性能。\n",
    "\n",
    "### 热节流模型\n",
    "\n",
    "```\n",
    "性能\n",
    "  ↑\n",
    "  │ ██████████████╲\n",
    "  │               ╲████████████████████\n",
    "  │                                    ← 稳态性能\n",
    "  └──────────────────────────────────→ 时间\n",
    "       ↑ 初始性能    ↑ 降频开始\n",
    "```\n",
    "\n",
    "### 热节流的影响因素\n",
    "\n",
    "| 因素 | 影响 | 典型值 |\n",
    "|------|------|--------|\n",
    "| **TDP** | 功耗越高, 发热越快, 降频越早 | 手机3-6W, 边缘10-60W |\n",
    "| **散热** | 被动散热降频快, 主动散热降频慢 | 手机被动, 服务器主动 |\n",
    "| **环境温度** | 温度越高, 降频越早 | 室温25°C vs 40°C |\n",
    "| **推理模式** | NPU比CPU/GPU能效高, 降频慢 | NPU 3-10x能效优势 |\n",
    "| **模型大小** | 大模型功耗高, 降频快 | 7B比1.5B降频快30-50% |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class ThermalThrottleSimulator:\n",
    "    \"\"\"热节流模拟器 - 预测不同硬件的持续性能\"\"\"\n",
    "    def __init__(self, tdp_watts, throttle_temp_c=45, ambient_temp_c=25,\n",
    "                 thermal_resistance_c_per_w=15, time_constant_s=30):\n",
    "        self.tdp = tdp_watts\n",
    "        self.throttle_temp = throttle_temp_c\n",
    "        self.ambient = ambient_temp_c\n",
    "        self.r_th = thermal_resistance_c_per_w\n",
    "        self.tau = time_constant_s\n",
    "        self.steady_state_temp = ambient_temp_c + tdp_watts * thermal_resistance_c_per_w\n",
    "\n",
    "    def temp_at_time(self, t_seconds):\n",
    "        \"\"\"计算t秒后的芯片温度\"\"\"\n",
    "        return self.ambient + (self.steady_state_temp - self.ambient) * (1 - np.exp(-t_seconds / self.tau))\n",
    "\n",
    "    def time_to_throttle(self):\n",
    "        \"\"\"计算从开始到触发降频的时间\"\"\"\n",
    "        if self.steady_state_temp < self.throttle_temp:\n",
    "            return float('inf')\n",
    "        delta = (self.throttle_temp - self.ambient) / (self.steady_state_temp - self.ambient)\n",
    "        return -self.tau * np.log(1 - delta)\n",
    "\n",
    "    def throttle_performance_ratio(self, t_seconds):\n",
    "        \"\"\"计算t秒后的性能比例 (1.0=满性能)\"\"\"\n",
    "        temp = self.temp_at_time(t_seconds)\n",
    "        if temp < self.throttle_temp:\n",
    "            return 1.0\n",
    "        overheat = temp - self.throttle_temp\n",
    "        throttle_ratio = max(0.5, 1.0 - overheat * 0.03)\n",
    "        return throttle_ratio\n",
    "\n",
    "    def simulate_sustained_inference(self, duration_minutes, initial_tps):\n",
    "        \"\"\"模拟持续推理的性能变化\"\"\"\",
    "        duration_s = duration_minutes * 60\n",
    "        n_points = min(duration_s, 120)\n",
    "        time_points = np.linspace(0, duration_s, n_points)\n",
    "        temps = [self.temp_at_time(t) for t in time_points]\n",
    "        perf_ratios = [self.throttle_performance_ratio(t) for t in time_points]\n",
    "        tps_values = [initial_tps * r for r in perf_ratios]\n",
    "        avg_tps = np.mean(tps_values[int(n_points*0.5):])\n",
    "        return {\n",
    "            'time_points_min': time_points / 60,\n",
    "            'temps_c': temps,\n",
    "            'perf_ratios': perf_ratios,\n",
    "            'tps_values': tps_values,\n",
    "            'avg_sustained_tps': avg_tps,\n",
    "            'time_to_throttle_s': self.time_to_throttle(),\n",
    "            'steady_state_temp': self.steady_state_temp,\n",
    "        }\n",
    "\n",
    "print(\"=== 热节流模拟: 不同设备的持续性能 ===\")\n",
    "devices = [\n",
    "    ('旗舰手机NPU', 5.0, 45, 15, 30),\n",
    "    ('中端手机NPU', 4.0, 42, 18, 25),\n",
    "    ('平板NPU', 8.0, 50, 12, 40),\n",
    "    ('边缘服务器', 25.0, 85, 5, 60),\n",
    "]\n",
    "\n",
    "for name, tdp, throttle_t, r_th, tau in devices:\n",
    "    sim = ThermalThrottleSimulator(tdp, throttle_t, 25, r_th, tau)\n",
    "    result = sim.simulate_sustained_inference(30, initial_tps=20)\n",
    "    t2t = result['time_to_throttle_s']\n",
    "    t2t_str = f\"{t2t:.0f}s\" if t2t < 3600 else \"不会降频\"\n",
    "    print(f\"\\n{name} (TDP={tdp}W):\")\n",
    "    print(f\"  稳态温度: {result['steady_state_temp']:.1f}°C\")\n",
    "    print(f\"  降频时间: {t2t_str}\")\n",
    "    print(f\"  30分钟持续性能: {result['avg_sustained_tps']:.1f} tok/s (初始20 tok/s)\")\n",
    "    print(f\"  性能维持率: {result['avg_sustained_tps']/20:.0%}\")\n",
    "\n",
    "print(f\"\\n=== 热节流应对策略 ===\")\n",
    "print(f\"1. 间歇推理: 每10秒推理后暂停2秒, 温度可降低5-10°C\")\n",
    "print(f\"2. 精度自适应: 温度高时切换到更低精度(W4A8), 降低功耗\")\n",
    "print(f\"3. 模型切换: 温度高时切换到更小模型(7B→1.5B), 功耗降低60%+\")\n",
    "print(f\"4. DVFS降频: 主动降低NPU频率, 功耗按V²f降低\")\n",
    "print(f\"5. NPU优先: NPU能效比CPU/GPU高3-10x, 尽量用NPU推理\")\n",
    "print(f\"6. 实际部署中, 热节流是常态而非异常, SLA必须基于持续性能\")"
   ]
  },
