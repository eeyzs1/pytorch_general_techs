    "class SpeculativeDecodingResult:\n",
    "    \"\"\"推测解码结果\"\"\"\n",
    "    def __init__(self):\n",
    "        self.total_draft_tokens = 0\n",
    "        self.total_accepted_tokens = 0\n",
    "        self.total_verification_steps = 0\n",
    "        self.total_cloud_calls = 0\n",
    "\n",
    "    @property\n",
    "    def accept_rate(self):\n",
    "        return self.total_accepted_tokens / max(self.total_draft_tokens, 1)\n",
    "\n",
    "    @property\n",
    "    def effective_speedup(self, k=5):\n",
    "        alpha_k = k * self.accept_rate\n",
    "        if alpha_k >= 1:\n",
    "            return float('inf')\n",
    "        return 1 / (1 - alpha_k)\n",
    "\n",
    "class EdgeCloudSpeculativeDecoding:\n",
    "    \"\"\"端云推测解码: 端侧draft + 云端verify\n",
    "    使用词汇表级别的token操作，模拟真实推测解码流程。\n",
    "    产业级实现参考: Medusa, SpecInfer, Eagle等框架。\"\"\"\n",
    "    def __init__(self, draft_model, target_model, vocab_size=1000, k=5, temperature=1.0):\n",
    "        self.draft_model = draft_model\n",
    "        self.target_model = target_model\n",
    "        self.vocab_size = vocab_size\n",
    "        self.k = k\n",
    "        self.temperature = temperature\n",
    "        self.stats = SpeculativeDecodingResult()\n",
    "\n",
    "    def _sample_token(self, logits):\n",
    "        probs = F.softmax(logits / self.temperature, dim=-1)\n",
    "        return torch.multinomial(probs, num_samples=1)\n",
    "\n",
    "    def draft_step(self, input_ids):\n",
    "        \"\"\"端侧draft: 自回归生成k个候选token\"\"\"\n",
    "        draft_tokens = []\n",
    "        draft_probs = []\n",
    "        current_ids = input_ids.clone()\n",
    "        with torch.no_grad():\n",
    "            for _ in range(self.k):\n",
    "                logits = self.draft_model(current_ids)\n",
    "                next_logits = logits[:, -1, :]\n",
    "                token = self._sample_token(next_logits)\n",
    "                draft_tokens.append(token)\n",
    "                draft_probs.append(F.softmax(next_logits, dim=-1))\n",
    "                current_ids = torch.cat([current_ids, token], dim=1)\n",
    "        return draft_tokens, draft_probs, current_ids\n",
    "\n",
    "    def verify_step(self, draft_ids, draft_probs):\n",
    "        \"\"\"云端verify: 一次前向传播验证所有draft token\"\"\"\n",
    "        with torch.no_grad():\n",
    "            target_logits = self.target_model(draft_ids)\n",
    "        n_draft = len(draft_probs)\n",
    "        seq_len = draft_ids.shape[1]\n",
    "        accepted = 0\n",
    "        for i in range(n_draft):\n",
    "            pos = seq_len - n_draft + i\n",
    "            target_prob = F.softmax(target_logits[:, pos, :], dim=-1)\n",
    "            draft_token = draft_ids[:, pos]\n",
    "            draft_p = draft_probs[i].gather(1, draft_token.unsqueeze(-1)).squeeze(-1)\n",
    "            target_p = target_prob.gather(1, draft_token.unsqueeze(-1)).squeeze(-1)\n",
    "            accept_prob = torch.min(torch.ones_like(target_p), target_p / (draft_p + 1e-10))\n",
    "            if torch.rand(1).item() < accept_prob.item():\n",
    "                accepted += 1\n",
    "            else:\n",
    "                break\n",
    "        self.stats.total_draft_tokens += n_draft\n",
    "        self.stats.total_accepted_tokens += accepted\n",
    "        self.stats.total_verification_steps += 1\n",
    "        self.stats.total_cloud_calls += 1\n",
    "        return accepted, n_draft\n",
    "\n",
    "    def decode_step(self, input_ids):\n",
    "        \"\"\"一步完整的推测解码\"\"\"\n",
    "        draft_tokens, draft_probs, draft_ids = self.draft_step(input_ids)\n",
    "        accepted, total = self.verify_step(draft_ids, draft_probs)\n",
    "        return accepted, total\n",
    "\n",
    "class DraftModel(nn.Module):\n",
    "    \"\"\"端侧draft模型: 轻量级语言模型\"\"\"\n",
    "    def __init__(self, vocab_size=1000, dim=64, n_layers=2, n_heads=4):\n",
    "        super().__init__()\n",
    "        self.embed = nn.Embedding(vocab_size, dim)\n",
    "        self.layers = nn.ModuleList([\n",
    "            nn.TransformerEncoderLayer(d_model=dim, nhead=n_heads, batch_first=True)\n",
    "            for _ in range(n_layers)\n",
    "        ])\n",
    "        self.head = nn.Linear(dim, vocab_size)\n",
    "\n",
    "    def forward(self, input_ids):\n",
    "        h = self.embed(input_ids)\n",
    "        for layer in self.layers:\n",
    "            h = layer(h)\n",
    "        return self.head(h)\n",
    "\n",
    "class TargetModel(nn.Module):\n",
    "    \"\"\"云端target模型: 大型语言模型\"\"\"\n",
    "    def __init__(self, vocab_size=1000, dim=128, n_layers=4, n_heads=4):\n",
    "        super().__init__()\n",
    "        self.embed = nn.Embedding(vocab_size, dim)\n",
    "        self.layers = nn.ModuleList([\n",
    "            nn.TransformerEncoderLayer(d_model=dim, nhead=n_heads, batch_first=True)\n",
    "            for _ in range(n_layers)\n",
    "        ])\n",
    "        self.head = nn.Linear(dim, vocab_size)\n",
    "\n",
    "    def forward(self, input_ids):\n",
    "        h = self.embed(input_ids)\n",
    "        for layer in self.layers:\n",
    "            h = layer(h)\n",
    "        return self.head(h)\n",
    "\n",
    "vocab_size = 200\n",
    "draft = DraftModel(vocab_size=vocab_size, dim=64, n_layers=2)\n",
    "target = TargetModel(vocab_size=vocab_size, dim=128, n_layers=4)\n",
    "ec_spec = EdgeCloudSpeculativeDecoding(draft, target, vocab_size=vocab_size, k=5, temperature=0.8)\n",
    "\n",
    "n_steps = 20\n",
    "for step in range(n_steps):\n",
    "    seq_len = np.random.randint(4, 10)\n",
    "    input_ids = torch.randint(0, vocab_size, (1, seq_len))\n",
    "    accepted, drafted = ec_spec.decode_step(input_ids)\n",
    "\n",
    "print(f\"=== 端云推测解码 ===\")\n",
    "print(f\"总draft tokens: {ec_spec.stats.total_draft_tokens}\")\n",
    "print(f\"总accepted tokens: {ec_spec.stats.total_accepted_tokens}\")\n",
    "print(f\"接受率: {ec_spec.stats.accept_rate:.2%}\")\n",
    "print(f\"云端调用次数: {ec_spec.stats.total_cloud_calls}\")\n",
    "print(f\"理论加速比(k=5): {ec_spec.stats.effective_speedup:.2f}x\")\n",
    "\n",
    "print(f\"\\n--- 不同k值的理论加速比（假设接受率80%） ---\")\n",
    "assumed_accept = 0.8\n",
    "for k in [3, 5, 7, 10]:\n",
    "    sp = 1 / (1 - k * assumed_accept) if k * assumed_accept < 1 else float('inf')\n",
    "    print(f\"  k={k}: 加速比={sp:.2f}x\")\n",
    "\n",
    "print(f\"\\n--- 产业级推测解码实践 ---\")\n",
    "print(f\"1. Medusa: 多头并行draft，每个head独立预测不同位置的token\")\n",
    "print(f\"2. SpecInfer: 树状推测，一个token多种可能，提高接受率\")\n",
    "print(f\"3. Eagle: 自回归draft + 特征级推测，减少draft延迟\")\n",
    "print(f\"4. 关键: draft模型与target模型的分布越接近，接受率越高\")\n",
    "print(f\"5. 典型配置: k=5, 接受率≈80%, 加速比≈2.5x\")"
   ]
