   "source": [
    "from collections import OrderedDict\n",
    "\n",
    "class LRUCache:\n",
    "    \"\"\"LRU缓存实现，用于Prompt/Prefix KV Cache\"\"\"\n",
    "    def __init__(self, max_size_bytes: int):\n",
    "        self.max_size = max_size_bytes\n",
    "        self.current_size = 0\n",
    "        self.cache: OrderedDict[str, Tuple[torch.Tensor, int]] = OrderedDict()\n",
    "        self.stats = {'hits': 0, 'misses': 0, 'evictions': 0}\n",
    "\n",
    "    def put(self, key: str, value: torch.Tensor):\n",
    "        size_bytes = value.numel() * value.element_size()\n",
    "        while self.current_size + size_bytes > self.max_size and self.cache:\n",
    "            evicted_key, (evicted_val, evicted_size) = self.cache.popitem(last=False)\n",
    "            self.current_size -= evicted_size\n",
    "            self.stats['evictions'] += 1\n",
    "        self.cache[key] = (value, size_bytes)\n",
    "        self.current_size += size_bytes\n",
    "\n",
    "    def get(self, key: str) -> Optional[torch.Tensor]:\n",
    "        if key in self.cache:\n",
    "            self.cache.move_to_end(key)\n",
    "            self.stats['hits'] += 1\n",
    "            return self.cache[key][0]\n",
    "        self.stats['misses'] += 1\n",
    "        return None\n",
    "\n",
    "    @property\n",
    "    def hit_rate(self):\n",
    "        total = self.stats['hits'] + self.stats['misses']\n",
    "        return self.stats['hits'] / total if total > 0 else 0.0\n",
    "\n",
    "class EdgeCacheManager:\n",
    "    \"\"\"边缘缓存管理器: 管理Prompt Cache、Prefix Cache、结果Cache\"\"\"\n",
    "    def __init__(self, max_cache_mb=512):\n",
    "        self.max_cache_bytes = max_cache_mb * 1024 * 1024\n",
    "        self.prompt_cache = LRUCache(self.max_cache_bytes // 2)\n",
    "        self.result_cache = LRUCache(self.max_cache_bytes // 4)\n",
    "        self.feature_cache = LRUCache(self.max_cache_bytes // 4)\n",
    "\n",
    "    def compute_kv_cache_size(self, seq_len, n_layers, n_kv_heads, head_dim, dtype_bytes=2):\n",
    "        return seq_len * n_layers * 2 * n_kv_heads * head_dim * dtype_bytes / 1e6\n",
    "\n",
    "    def estimate_prompt_cache_savings(self, prefix_len, n_layers, n_kv_heads, head_dim, n_requests):\n",
    "        kv_size_mb = self.compute_kv_cache_size(prefix_len, n_layers, n_kv_heads, head_dim)\n",
    "        flops_per_prefix = prefix_len * n_layers * 2 * (n_kv_heads * head_dim) * (4 * n_kv_heads * head_dim)\n",
    "        total_flops_saved = flops_per_prefix * n_requests\n",
    "        return {\n",
    "            'cache_size_mb': kv_size_mb,\n",
    "            'flops_saved_per_request_gflops': flops_per_prefix / 1e9,\n",
    "            'total_flops_saved_gflops': total_flops_saved / 1e9,\n",
    "            'fits_cache': kv_size_mb * 1024 * 1024 <= self.max_cache_bytes // 2,\n",
    "        }\n",
    "\n",
    "cache_mgr = EdgeCacheManager(max_cache_mb=512)\n",
    "\n",
    "print(\"=== 边缘KV Cache分析 (7B模型) ===\")\n",
    "print(f\"\\n--- KV Cache大小估算 ---\")\n",
    "for seq_len in [128, 512, 2048, 8192]:\n",
    "    size = cache_mgr.compute_kv_cache_size(seq_len, 32, 32, 128)\n",
    "    size_int8 = cache_mgr.compute_kv_cache_size(seq_len, 32, 32, 128, dtype_bytes=1)\n",
    "    print(f\"  seq_len={seq_len:<6} FP16: {size:.1f}MB  INT8: {size_int8:.1f}MB\")\n",
    "\n",
    "print(f\"\\n--- Prompt Cache收益分析 (500 token系统提示词) ---\")\n",
    "for n_requests in [1, 10, 100, 1000]:\n",
    "    result = cache_mgr.estimate_prompt_cache_savings(500, 32, 32, 128, n_requests)\n",
    "    print(f\"  {n_requests}次请求: 缓存{result['cache_size_mb']:.1f}MB, \"\n",
    "          f\"节省{result['flops_saved_per_request_gflops']:.1f}GFLOPs/请求, \"\n",
    "          f\"适合缓存: {'是' if result['fits_cache'] else '否'}\")\n",
    "\n",
    "print(f\"\\n--- LRU缓存模拟 ---\")\n",
    "prompt_cache = cache_mgr.prompt_cache\n",
    "system_prompts = {\n",
    "    'default_assistant': torch.randn(500, 32, 128),\n",
    "    'code_helper': torch.randn(300, 32, 128),\n",
    "    'translator': torch.randn(200, 32, 128),\n",
    "}\n",
    "for name, kv in system_prompts.items():\n",
    "    prompt_cache.put(f'prompt_{name}', kv)\n",
    "\n",
    "np.random.seed(42)\n",
    "for _ in range(100):\n",
    "    key = np.random.choice(list(system_prompts.keys()))\n",
    "    prompt_cache.get(f'prompt_{key}')\n",
    "    if np.random.random() < 0.1:\n",
    "        new_key = f'prompt_adhoc_{np.random.randint(100)}'\n",
    "        prompt_cache.put(new_key, torch.randn(100, 32, 128))\n",
    "\n",
    "print(f\"  缓存命中率: {prompt_cache.hit_rate:.1%}\")\n",
    "print(f\"  驱逐次数: {prompt_cache.stats['evictions']}\")\n",
    "print(f\"  当前缓存项: {len(prompt_cache.cache)}\")\n",
    "\n",
    "print(f\"\\n=== 产业实践要点 ===\")\n",
    "print(f\"1. Prompt Cache是最高ROI的优化: 系统提示词命中率>80%\")\n",
    "print(f\"2. KV Cache量化(INT8)可减少50%缓存大小，精度损失<0.1%\")\n",
    "print(f\"3. PagedAttention管理KV Cache内存，消除碎片\")\n",
    "print(f\"4. 增量传输: 多轮对话仅传输新增token的KV\")\n",
    "print(f\"5. 缓存淘汰策略: LRU适合通用场景，前缀匹配需要定制策略\")"
   ]
