    "class EdgeCloudPipeline:\n",
    "    \"\"\"端云协同推理完整Pipeline\"\"\"\n",
    "    def __init__(self, edge_model, cloud_model, dim=64, vocab_size=1000):\n",
    "        self.edge_model = edge_model\n",
    "        self.cloud_model = cloud_model\n",
    "        self.router = AdaptiveInferenceRouter(edge_model, cloud_model)\n",
    "        self.scheduler = NetworkAdaptiveScheduler()\n",
    "        self.cache_mgr = EdgeCacheManager(max_cache_mb=256)\n",
    "        self.verifier = ConsistencyVerifier()\n",
    "        self.pipeline_stats = {\n",
    "            'total_requests': 0, 'edge_requests': 0, 'cloud_requests': 0,\n",
    "            'split_requests': 0, 'cache_hits': 0, 'privacy_overrides': 0,\n",
    "            'total_latency_ms': 0, 'total_cost_usd': 0,\n",
    "        }\n",
    "\n",
    "    def _check_cache(self, request_id: str) -> Optional[torch.Tensor]:\n",
    "        cached = self.cache_mgr.result_cache.get(f'result_{request_id}')\n",
    "        if cached is not None:\n",
    "            self.pipeline_stats['cache_hits'] += 1\n",
    "            return cached\n",
    "        return None\n",
    "\n",
    "    def process_request(self, request_id: str, input_tensor: torch.Tensor,\n",
    "                         task_type: str = 'chat', privacy_level: str = 'normal',\n",
    "                         network_condition: Optional[NetworkCondition] = None) -> Dict:\n",
    "        \"\"\"处理单个推理请求\"\"\"\n",
    "        start_time = time.perf_counter()\n",
    "        self.pipeline_stats['total_requests'] += 1\n",
    "\n",
    "        cached_result = self._check_cache(request_id)\n",
    "        if cached_result is not None:\n",
    "            latency = (time.perf_counter() - start_time) * 1000\n",
    "            return {'source': 'cache', 'latency_ms': latency, 'cost_usd': 0.0}\n",
    "\n",
    "        req = RoutingRequest(\n",
    "            request_id=request_id,\n",
    "            input_tokens=input_tensor.shape[1] if input_tensor.dim() == 3 else 1,\n",
    "            task_type=task_type,\n",
    "            embedding=input_tensor,\n",
    "            privacy_level=privacy_level,\n",
    "        )\n",
    "        decision = self.router.route(req)\n",
    "\n",
    "        with torch.no_grad():\n",
    "            if decision.target == 'edge':\n",
    "                result = self.edge_model(input_tensor)\n",
    "                self.pipeline_stats['edge_requests'] += 1\n",
    "                source = 'edge'\n",
    "            else:\n",
    "                if network_condition and network_condition.quality in ('excellent', 'good'):\n",
    "                    result = self.cloud_model(input_tensor)\n",
    "                    self.pipeline_stats['cloud_requests'] += 1\n",
    "                    source = 'cloud'\n",
    "                else:\n",
    "                    result = self.edge_model(input_tensor)\n",
    "                    self.pipeline_stats['edge_requests'] += 1\n",
    "                    source = 'edge_fallback'\n",
    "\n",
    "        latency = (time.perf_counter() - start_time) * 1000\n",
    "        cost = decision.cost_estimate_usd\n",
    "        self.pipeline_stats['total_latency_ms'] += latency\n",
    "        self.pipeline_stats['total_cost_usd'] += cost\n",
    "\n",
    "        self.cache_mgr.result_cache.put(f'result_{request_id}', result)\n",
    "\n",
    "        return {\n",
    "            'source': source, 'latency_ms': latency, 'cost_usd': cost,\n",
    "            'routing_reason': decision.reason,\n",
    "        }\n",
    "\n",
    "    def get_stats(self) -> Dict:\n",
    "        stats = self.pipeline_stats.copy()\n",
    "        if stats['total_requests'] > 0:\n",
    "            stats['avg_latency_ms'] = stats['total_latency_ms'] / stats['total_requests']\n",
    "            stats['edge_ratio'] = stats['edge_requests'] / stats['total_requests']\n",
    "            stats['cache_hit_rate'] = stats['cache_hits'] / stats['total_requests']\n",
    "        return stats\n",
    "\n",
    "edge = nn.Sequential(nn.Linear(64, 32), nn.ReLU(), nn.Linear(32, 64))\n",
    "cloud = nn.Sequential(nn.Linear(64, 128), nn.ReLU(), nn.Linear(128, 64), nn.ReLU(), nn.Linear(64, 64))\n",
    "pipeline = EdgeCloudPipeline(edge, cloud, dim=64)\n",
    "\n",
    "test_scenarios = [\n",
    "    ('req_001', 'chat', 'normal', NetworkCondition(10, 500)),\n",
    "    ('req_002', 'reasoning', 'normal', NetworkCondition(20, 200)),\n",
    "    ('req_003', 'chat', 'sensitive', NetworkCondition(50, 30)),\n",
    "    ('req_004', 'creative_writing', 'normal', NetworkCondition(100, 10)),\n",
    "    ('req_005', 'translation', 'normal', NetworkCondition(10, 500)),\n",
    "    ('req_001', 'chat', 'normal', NetworkCondition(10, 500)),\n",
    "]\n",
    "\n",
    "print(\"=== 端云协同推理Pipeline ===\")\n",
    "print(f\"\\n{'请求ID':<10} {'任务':<15} {'隐私':<8} {'网络':<8} {'来源':<15} {'延迟(ms)':<10} {'成本($)':<8}\")\n",
    "print(\"-\" * 80)\n",
    "for req_id, task, privacy, network in test_scenarios:\n",
    "    x = torch.randn(1, np.random.randint(2, 8), 64)\n",
    "    result = pipeline.process_request(req_id, x, task, privacy, network)\n",
    "    print(f\"{req_id:<10} {task:<15} {privacy:<8} {network.quality:<8} \"\n",
    "          f\"{result['source']:<15} {result['latency_ms']:<10.1f} {result['cost_usd']:<8.4f}\")\n",
    "\n",
    "stats = pipeline.get_stats()\n",
    "print(f\"\\n--- Pipeline统计 ---\")\n",
    "print(f\"总请求: {stats['total_requests']}\")\n",
    "print(f\"端侧处理: {stats['edge_requests']} ({stats.get('edge_ratio', 0):.0%})\")\n",
    "print(f\"云端处理: {stats['cloud_requests']}\")\n",
    "print(f\"缓存命中: {stats['cache_hits']} ({stats.get('cache_hit_rate', 0):.0%})\")\n",
    "print(f\"平均延迟: {stats.get('avg_latency_ms', 0):.1f}ms\")\n",
    "print(f\"总成本: ${stats['total_cost_usd']:.4f}\")"
   ]
